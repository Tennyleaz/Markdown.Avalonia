<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  
  <PropertyGroup>
    <DemoAppTargetFrameworks>net8</DemoAppTargetFrameworks>
    <TestTargetFrameworks>net8</TestTargetFrameworks>
    <PackageTargetFrameworks>net8</PackageTargetFrameworks>
    <AvaloniaVersion>12.0.0</AvaloniaVersion>
    <DemoAvaloniaVersion>12.0.999-cibuild0060150-alpha</DemoAvaloniaVersion>
    <EnableAvaloniaEdit>enabled</EnableAvaloniaEdit>
    <AvaloniaEditVersion>12.0.0-rc1</AvaloniaEditVersion>
    <AvaloniaSvgVersion>12.0.0.5</AvaloniaSvgVersion>

    <PackageProjectUrl>https://github.com/ClassIsland/Markdown.Avalonia</PackageProjectUrl>
    
  </PropertyGroup>

  <PropertyGroup Condition=" '$(AVA_VER)' != '' ">
    <TestAvaloniaVersion>$(AVA_VER)</TestAvaloniaVersion>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(AVA_VER)' == '' ">
    <TestAvaloniaVersion>$(AvaloniaVersion)</TestAvaloniaVersion>
  </PropertyGroup>

  <PropertyGroup>
    <PackageVersion>12.0.0</PackageVersion>
  </PropertyGroup>

</Project>


